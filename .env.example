# MySQL target
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=etl
MYSQL_PASSWORD=changeme
MYSQL_DATABASE=logs

# GCS
GCS_BUCKET=your-bucket-name
GCS_PREFIX=nginx-logs
GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa-key.json
